{
	"name": "@spider-cloud/n8n-nodes-spider",
	"version": "1.0.5",
	"description": "n8n community node for Spider – the fastest web crawling and scraping API for AI agents",
	"keywords": [
		"n8n-community-node-package"
	],
	"license": "MIT",
	"homepage": "https://spider.cloud",
	"author": {
		"name": "William Espegren",
		"email": "espegren.w@gmail.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/spider-rs/n8n-nodes-spider.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/SpiderApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Spider/Spider.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"typescript": "^5.3.3",
		"eslint": "^9.0.0",
		"prettier": "^3.2.5",
		"release-it": "^17.1.1"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"publishConfig": {
		"access": "public"
	}
}
